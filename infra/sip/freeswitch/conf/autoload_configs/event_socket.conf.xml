<configuration name="event_socket.conf" description="Socket Client">
  <settings>
    <param name="nat-map" value="false"/>
    <!--
      Bind to 0.0.0.0 not '::'. The default IPv6-any binding fails inside our
      arm64 Linux container ("Cannot get information about IP address ::"),
      which kills mod_event_socket on startup. apps/api connects via the
      published host port 8121 → container 8021.
    -->
    <param name="listen-ip" value="0.0.0.0"/>
    <param name="listen-port" value="8021"/>
    <param name="password" value="ClueCon"/>
    <!--
      esl_clients ACL defined in acl.conf.xml. Allows loopback + private
      ranges (covers docker bridge + host-via-port-mapping). Host port is
      127.0.0.1-only, so external probes never reach this.
    -->
    <param name="apply-inbound-acl" value="esl_clients"/>
  </settings>
</configuration>
