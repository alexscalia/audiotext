{
  "name": "@audiotext/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts"
  },
  "scripts": {
    "lint": "echo \"no lint\"",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx --env-file=../../.env src/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx --env-file=../../.env src/seed.ts",
    "db:reset": "tsx --env-file=../../.env src/reset.ts && pnpm db:migrate && pnpm db:seed"
  },
  "dependencies": {
    "drizzle-orm": "0.45.2",
    "pg": "8.20.0"
  },
  "devDependencies": {
    "@audiotext/tsconfig": "workspace:*",
    "@types/pg": "8.20.0",
    "better-auth": "^1.6.9",
    "drizzle-kit": "0.31.10",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3"
  }
}
