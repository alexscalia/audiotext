DATABASE_URL=postgresql://audiotext:audiotext@localhost:5433/audiotext

# Better Auth — required in production. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Origin allowed by Better Auth's CSRF check (web app's origin)
WEB_ORIGIN=http://localhost:3000

# Server-side proxy target for /api/auth/* rewrite in apps/web/next.config.ts
API_URL=http://localhost:3101

# Port the Hono api listens on (apps/api). Keep in sync with API_URL above.
PORT=3101

# App timezone (IANA, e.g. "Europe/Rome", "America/New_York"). Used for display/scheduling. Server TZ stays UTC.
APP_TIMEZONE=UTC

# Redis — used by sip-signaling (pub/sub + quota counters) and api (CDR settle).
REDIS_URL=redis://localhost:6379

# FreeSWITCH ESL — CDR listener subscribes to CHANNEL_DESTROY here.
# Set CDR_LISTENER_ENABLED=false to skip starting the listener (dev without FS).
FREESWITCH_ESL_HOST=localhost
FREESWITCH_ESL_PORT=8021
FREESWITCH_ESL_PASSWORD=ClueCon
CDR_LISTENER_ENABLED=true

# Voice trunk credential encryption key (AES-256-GCM). 32 random bytes, base64.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TRUNK_SECRET_KEY=
