DATABASE_URL=postgresql://audiotext:audiotext@localhost:5432/audiotext

# Better Auth — required in production. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Origin allowed by Better Auth's CSRF check (web app's origin)
WEB_ORIGIN=http://localhost:3000

# Server-side proxy target for /api/auth/* rewrite in apps/web/next.config.ts
API_URL=http://localhost:3001
